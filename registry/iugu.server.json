{
  "name": "io.github.codespar/mcp-iugu",
  "description": "Invoices, subscriptions, customers — iugu API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/iugu"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-iugu",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "IUGU_API_TOKEN", "description": "API token from iugu", "required": true },
        { "name": "IUGU_SANDBOX", "description": "Set to 'true' for test mode", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_invoice", "description": "Create an invoice (Pix, boleto, or credit card)" },
    { "name": "get_invoice", "description": "Get invoice details by ID" },
    { "name": "list_invoices", "description": "List invoices with filters" },
    { "name": "create_customer", "description": "Create a customer" },
    { "name": "list_customers", "description": "List customers with filters" },
    { "name": "create_subscription", "description": "Create a recurring subscription" },
    { "name": "create_payment_method", "description": "Create a payment method for a customer" },
    { "name": "get_account_info", "description": "Get account information and balance" }
  ]
}
