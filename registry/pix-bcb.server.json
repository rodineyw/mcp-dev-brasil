{
  "name": "io.github.codespar/mcp-pix-bcb",
  "description": "Official Pix API (BCB) — charges, payments, keys, DICT",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/pix-bcb"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-pix-bcb",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "PIX_BASE_URL", "description": "PSP API base URL", "required": true },
        { "name": "PIX_CLIENT_ID", "description": "OAuth2 client ID", "required": true },
        { "name": "PIX_CLIENT_SECRET", "description": "OAuth2 client secret", "required": true },
        { "name": "PIX_CERT_PATH", "description": "Path to mTLS certificate (.pem or .p12)", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_cob", "description": "Create an immediate Pix charge" },
    { "name": "get_cob", "description": "Get immediate charge details by txid" },
    { "name": "list_cobs", "description": "List immediate charges with filters" },
    { "name": "create_cobv", "description": "Create a due-date Pix charge" },
    { "name": "get_pix", "description": "Get a received Pix payment by e2eid" },
    { "name": "list_pix_received", "description": "List received Pix payments" },
    { "name": "create_pix_key", "description": "Register a Pix key (DICT)" },
    { "name": "get_pix_key", "description": "Look up a Pix key" }
  ]
}
