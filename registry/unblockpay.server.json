{
  "name": "io.github.codespar/mcp-unblockpay",
  "description": "Wallets, onramp, offramp, stablecoin transfers — UnblockPay API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/crypto/unblockpay"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-unblockpay",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "UNBLOCKPAY_API_KEY", "description": "API key from UnblockPay", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "create_wallet", "description": "Create a new wallet" },
    { "name": "get_wallet", "description": "Get wallet details by ID" },
    { "name": "list_wallets", "description": "List all wallets" },
    { "name": "create_onramp", "description": "Create a fiat-to-stablecoin onramp transaction" },
    { "name": "create_offramp", "description": "Create a stablecoin-to-fiat offramp transaction" },
    { "name": "get_transaction", "description": "Get transaction details by ID" },
    { "name": "list_transactions", "description": "List transactions with filters" },
    { "name": "get_exchange_rate", "description": "Get current exchange rate" },
    { "name": "create_transfer", "description": "Create a stablecoin transfer between wallets" },
    { "name": "get_balance", "description": "Get wallet balance" }
  ]
}
