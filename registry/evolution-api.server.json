{
  "name": "io.github.codespar/mcp-evolution-api",
  "description": "Self-hosted WhatsApp API — messages, instances, groups, polls — Evolution API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/communication/evolution-api"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-evolution-api",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "EVOLUTION_API_URL", "description": "Base URL of self-hosted Evolution API", "required": true },
        { "name": "EVOLUTION_API_KEY", "description": "API key for authentication", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "send_text", "description": "Send a text message" },
    { "name": "send_image", "description": "Send an image message" },
    { "name": "send_document", "description": "Send a document" },
    { "name": "get_instances", "description": "List all instances" },
    { "name": "create_instance", "description": "Create a new WhatsApp instance" },
    { "name": "get_qrcode", "description": "Get QR code for instance pairing" },
    { "name": "get_contacts", "description": "Get contacts from an instance" },
    { "name": "send_poll", "description": "Send a poll message" },
    { "name": "get_messages", "description": "Get messages from a chat" },
    { "name": "check_number", "description": "Check if a number is on WhatsApp" },
    { "name": "create_group", "description": "Create a WhatsApp group" },
    { "name": "get_group_info", "description": "Get group metadata and participants" },
    { "name": "update_profile", "description": "Update instance profile" },
    { "name": "set_presence", "description": "Set online/offline presence" },
    { "name": "get_chat_history", "description": "Get full chat history with pagination" }
  ]
}
