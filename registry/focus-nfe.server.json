{
  "name": "io.github.codespar/mcp-focus-nfe",
  "description": "NFe, NFSe, NFCe emission and management — Focus NFe API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/fiscal/focus-nfe"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-focus-nfe",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "FOCUS_NFE_TOKEN", "description": "API token from Focus NFe", "required": true },
        { "name": "FOCUS_NFE_SANDBOX", "description": "Set to 'true' for homologation", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_nfe", "description": "Create and emit an NFe (nota fiscal eletronica)" },
    { "name": "get_nfe", "description": "Get NFe details by reference" },
    { "name": "cancel_nfe", "description": "Cancel an NFe" },
    { "name": "create_nfse", "description": "Create and emit an NFSe (nota fiscal de servico)" },
    { "name": "get_nfse", "description": "Get NFSe details by reference" },
    { "name": "cancel_nfse", "description": "Cancel an NFSe" },
    { "name": "get_nfe_pdf", "description": "Get NFe PDF (DANFE) download URL" },
    { "name": "create_nfce", "description": "Create and emit an NFCe (nota fiscal do consumidor)" }
  ]
}
