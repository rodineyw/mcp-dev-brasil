{
  "name": "io.github.codespar/mcp-vtex",
  "description": "Products, orders, SKUs, inventory, promotions, catalog — VTEX API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/ecommerce/vtex"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-vtex",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "VTEX_ACCOUNT_NAME", "description": "VTEX account name", "required": true },
        { "name": "VTEX_APP_KEY", "description": "API app key", "required": true },
        { "name": "VTEX_APP_TOKEN", "description": "API app token", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "list_products", "description": "List products from catalog" },
    { "name": "get_product", "description": "Get product details by ID" },
    { "name": "list_orders", "description": "List orders with filters" },
    { "name": "get_order", "description": "Get order details by ID" },
    { "name": "list_skus", "description": "List SKUs for a product" },
    { "name": "get_inventory", "description": "Get inventory/stock for a SKU" },
    { "name": "update_inventory", "description": "Update inventory for a SKU" },
    { "name": "get_shipping_rates", "description": "Get shipping rates simulation" },
    { "name": "create_promotion", "description": "Create a promotion/discount" },
    { "name": "get_catalog", "description": "Get catalog category tree" },
    { "name": "create_product", "description": "Create a new product" },
    { "name": "update_product", "description": "Update an existing product" },
    { "name": "create_sku", "description": "Create a new SKU" },
    { "name": "create_category", "description": "Create a new category" },
    { "name": "list_categories", "description": "List categories" }
  ]
}
