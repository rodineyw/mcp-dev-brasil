{
  "name": "io.github.codespar/mcp-vindi",
  "description": "Recurring billing, subscriptions, plans, customers — Vindi API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/vindi"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-vindi",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "VINDI_API_KEY", "description": "API key from Vindi", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "create_subscription", "description": "Create a recurring subscription" },
    { "name": "get_subscription", "description": "Get subscription details" },
    { "name": "list_subscriptions", "description": "List subscriptions with filters" },
    { "name": "create_bill", "description": "Create a bill (charge)" },
    { "name": "get_bill", "description": "Get bill details" },
    { "name": "list_bills", "description": "List bills with filters" },
    { "name": "create_customer", "description": "Create a customer" },
    { "name": "get_customer", "description": "Get customer details" },
    { "name": "create_plan", "description": "Create a billing plan" },
    { "name": "list_plans", "description": "List available plans" }
  ]
}
