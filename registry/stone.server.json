{
  "name": "io.github.codespar/mcp-stone",
  "description": "Open banking, payments, Pix, transfers, statements — Stone API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/stone"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-stone",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "STONE_CLIENT_ID", "description": "OAuth2 client ID", "required": true },
        { "name": "STONE_CLIENT_SECRET", "description": "OAuth2 client secret", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "create_payment", "description": "Create a payment via Stone" },
    { "name": "get_payment", "description": "Get payment details by ID" },
    { "name": "list_payments", "description": "List payments with filters" },
    { "name": "get_balance", "description": "Get account balance" },
    { "name": "list_transactions", "description": "List account transactions" },
    { "name": "create_transfer", "description": "Create a bank transfer" },
    { "name": "get_statement", "description": "Get account statement" },
    { "name": "create_pix_payment", "description": "Create a Pix payment" }
  ]
}
