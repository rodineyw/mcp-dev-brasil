{
  "name": "io.github.codespar/mcp-celcoin",
  "description": "Pix, boleto, transfers, top-ups — Celcoin fintech infrastructure API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/celcoin"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-celcoin",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "CELCOIN_CLIENT_ID", "description": "OAuth2 client ID", "required": true },
        { "name": "CELCOIN_CLIENT_SECRET", "description": "OAuth2 client secret", "required": true },
        { "name": "CELCOIN_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_pix_payment", "description": "Create a Pix payment" },
    { "name": "get_pix_payment", "description": "Get Pix payment details" },
    { "name": "create_boleto", "description": "Create a boleto payment" },
    { "name": "get_boleto", "description": "Get boleto details" },
    { "name": "create_transfer", "description": "Create a bank transfer (TED/DOC)" },
    { "name": "get_balance", "description": "Get account balance" },
    { "name": "list_banks", "description": "List available banks" },
    { "name": "create_topup", "description": "Create a mobile/service top-up (recarga)" }
  ]
}
