{
  "name": "io.github.codespar/mcp-stark-bank",
  "description": "Transfers, boletos, invoices, Pix, payment requests — Stark Bank API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/banking/stark-bank"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-stark-bank",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "STARK_BANK_ACCESS_TOKEN", "description": "API access token", "required": true },
        { "name": "STARK_BANK_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_transfer", "description": "Create a bank transfer" },
    { "name": "get_transfer", "description": "Get transfer details by ID" },
    { "name": "list_transfers", "description": "List transfers with filters" },
    { "name": "create_boleto", "description": "Create a boleto payment" },
    { "name": "get_balance", "description": "Get account balance" },
    { "name": "create_invoice", "description": "Create an invoice" },
    { "name": "get_invoice", "description": "Get invoice details by ID" },
    { "name": "list_invoices", "description": "List invoices with filters" },
    { "name": "create_pix_request", "description": "Create a Pix payment request" },
    { "name": "get_webhook_events", "description": "Get webhook events" },
    { "name": "create_payment_request", "description": "Create a payment request for approval" },
    { "name": "get_payment_request", "description": "Get payment request details" },
    { "name": "list_payment_requests", "description": "List payment requests" },
    { "name": "create_brcode_payment", "description": "Pay a BR Code (Pix QR code)" },
    { "name": "get_deposit", "description": "Get deposit details by ID" }
  ]
}
