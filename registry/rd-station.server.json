{
  "name": "io.github.codespar/mcp-rd-station",
  "description": "CRM contacts, events, funnels, opportunities — RD Station API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/communication/rd-station"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-rd-station",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "RD_STATION_TOKEN", "description": "Bearer token from RD Station", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "create_contact", "description": "Create a contact in RD Station CRM" },
    { "name": "update_contact", "description": "Update a contact by UUID" },
    { "name": "get_contact", "description": "Get contact details by UUID or email" },
    { "name": "list_contacts", "description": "List contacts with pagination" },
    { "name": "create_event", "description": "Create a conversion event" },
    { "name": "list_funnels", "description": "List sales funnels" },
    { "name": "get_funnel", "description": "Get funnel details with stages" },
    { "name": "create_opportunity", "description": "Create a sales opportunity" }
  ]
}
