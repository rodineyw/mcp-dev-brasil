{
  "name": "io.github.codespar/mcp-circle",
  "description": "USDC wallets, payments, payouts, transfers — Circle API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/crypto/circle"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-circle",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "CIRCLE_API_KEY", "description": "API key from Circle", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "create_wallet", "description": "Create a new Circle wallet" },
    { "name": "get_wallet", "description": "Get wallet details by ID" },
    { "name": "create_payment", "description": "Accept a USDC payment" },
    { "name": "get_payment", "description": "Get payment details by ID" },
    { "name": "create_payout", "description": "Create a payout (USDC to fiat)" },
    { "name": "get_payout", "description": "Get payout details by ID" },
    { "name": "create_transfer", "description": "Create a USDC transfer between wallets" },
    { "name": "get_transfer", "description": "Get transfer details by ID" },
    { "name": "get_balance", "description": "Get wallet balance" },
    { "name": "list_transactions", "description": "List transactions with filters" }
  ]
}
