{
  "name": "io.github.codespar/mcp-take-blip",
  "description": "Chatbot messaging, contacts, broadcasts, analytics — Take Blip API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/communication/take-blip"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-take-blip",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "TAKE_BLIP_BOT_ID", "description": "Bot identifier", "required": true },
        { "name": "TAKE_BLIP_ACCESS_KEY", "description": "Bot access key", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "send_message", "description": "Send a message to a contact" },
    { "name": "get_contacts", "description": "List contacts" },
    { "name": "create_contact", "description": "Create a contact" },
    { "name": "get_threads", "description": "Get message threads" },
    { "name": "send_notification", "description": "Send a notification/broadcast message" },
    { "name": "get_analytics", "description": "Get chatbot analytics" },
    { "name": "create_broadcast", "description": "Create a broadcast list and send" },
    { "name": "get_chatbot_flow", "description": "Get chatbot flow configuration" }
  ]
}
