{
  "name": "io.github.codespar/mcp-open-finance",
  "description": "Accounts, transactions, consents, credit cards, investments — Open Finance Brasil API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/banking/open-finance"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-open-finance",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "OPEN_FINANCE_BASE_URL", "description": "Institution API base URL", "required": true },
        { "name": "OPEN_FINANCE_CLIENT_ID", "description": "OAuth2 client ID", "required": true },
        { "name": "OPEN_FINANCE_CLIENT_SECRET", "description": "OAuth2 client secret", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "list_accounts", "description": "List customer accounts" },
    { "name": "get_account_balance", "description": "Get account balance" },
    { "name": "list_transactions", "description": "List account transactions" },
    { "name": "get_consent", "description": "Get consent details" },
    { "name": "create_consent", "description": "Create a new consent request" },
    { "name": "list_credit_cards", "description": "List credit card accounts" },
    { "name": "get_credit_card_transactions", "description": "Get credit card transactions" },
    { "name": "list_investments", "description": "List investment products" }
  ]
}
