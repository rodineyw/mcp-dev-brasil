{
  "name": "io.github.codespar/mcp-melhor-envio",
  "description": "Shipping rates, labels, tracking, agencies — Melhor Envio API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/ecommerce/melhor-envio"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-melhor-envio",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "MELHOR_ENVIO_TOKEN", "description": "Bearer token from Melhor Envio", "required": true },
        { "name": "MELHOR_ENVIO_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "calculate_shipping", "description": "Calculate shipping rates from multiple carriers" },
    { "name": "create_shipment", "description": "Create a shipment order" },
    { "name": "track_shipment", "description": "Track a shipment by ID" },
    { "name": "generate_label", "description": "Generate shipping label" },
    { "name": "list_agencies", "description": "List carrier pickup agencies" },
    { "name": "cancel_shipment", "description": "Cancel a shipment" },
    { "name": "get_balance", "description": "Get account balance" },
    { "name": "add_cart", "description": "Add shipment to cart for batch processing" },
    { "name": "checkout_cart", "description": "Checkout all items in cart and pay" },
    { "name": "preview_label", "description": "Preview a shipping label" },
    { "name": "print_label", "description": "Print/download label PDF" },
    { "name": "get_shipment", "description": "Get shipment order details" },
    { "name": "list_shipments", "description": "List all shipment orders" },
    { "name": "get_store", "description": "Get store/company info" },
    { "name": "search_agencies", "description": "Search pickup agencies by service and location" },
    { "name": "create_address", "description": "Create a stored address" },
    { "name": "list_services_available", "description": "List available shipping services for a route" },
    { "name": "get_tracking_history", "description": "Get complete tracking history" }
  ]
}
