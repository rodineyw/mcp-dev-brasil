{
  "name": "io.github.codespar/mcp-pagseguro",
  "description": "Orders, charges, Pix, subscriptions, splits — PagSeguro/PagBank API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/pagseguro"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-pagseguro",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "PAGSEGURO_TOKEN", "description": "Bearer token from PagSeguro", "required": true },
        { "name": "PAGSEGURO_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_order", "description": "Create an order (Pix, boleto, or credit card)" },
    { "name": "get_order", "description": "Get order details by ID" },
    { "name": "list_orders", "description": "List orders with filters" },
    { "name": "create_charge", "description": "Create a standalone charge" },
    { "name": "refund", "description": "Refund a charge (full or partial)" },
    { "name": "get_pix_qrcode", "description": "Get Pix QR code for a charge" },
    { "name": "create_customer", "description": "Create a customer" },
    { "name": "get_balance", "description": "Get account balance" },
    { "name": "create_subscription", "description": "Create a recurring subscription" },
    { "name": "list_subscriptions", "description": "List subscriptions with filters" },
    { "name": "get_notifications", "description": "Get payment notification details" },
    { "name": "create_split", "description": "Create a split payment configuration" },
    { "name": "get_dispute", "description": "Get dispute/chargeback details" }
  ]
}
