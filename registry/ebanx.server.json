{
  "name": "io.github.codespar/mcp-ebanx",
  "description": "Cross-border payments, payouts, exchange rates — EBANX API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/ebanx"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-ebanx",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "EBANX_INTEGRATION_KEY", "description": "Integration key from EBANX dashboard", "required": true },
        { "name": "EBANX_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_payment", "description": "Create a payment (boleto, credit card, PIX, etc.)" },
    { "name": "get_payment", "description": "Get payment details by hash" },
    { "name": "list_payments", "description": "List payments by date range" },
    { "name": "refund", "description": "Refund a payment (full or partial)" },
    { "name": "create_payout", "description": "Create a payout to a bank account" },
    { "name": "exchange_rate", "description": "Get current exchange rate" },
    { "name": "get_banks", "description": "List available banks for a country" }
  ]
}
