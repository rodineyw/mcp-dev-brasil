{
  "name": "io.github.codespar/mcp-omie",
  "description": "Customers, products, orders, invoices, financials — Omie ERP API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/erp/omie"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-omie",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "OMIE_APP_KEY", "description": "Omie app key", "required": true },
        { "name": "OMIE_APP_SECRET", "description": "Omie app secret", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "list_customers", "description": "List customers" },
    { "name": "create_customer", "description": "Create a customer" },
    { "name": "list_products", "description": "List products" },
    { "name": "create_product", "description": "Create a product" },
    { "name": "create_order", "description": "Create a sales order" },
    { "name": "list_orders", "description": "List sales orders" },
    { "name": "list_invoices", "description": "List invoices (NF)" },
    { "name": "get_financial", "description": "List accounts receivable" },
    { "name": "create_invoice", "description": "Consult a specific NF" },
    { "name": "get_company_info", "description": "List companies" },
    { "name": "create_service_order", "description": "Create a service order (OS)" },
    { "name": "list_service_orders", "description": "List service orders" },
    { "name": "create_purchase_order", "description": "Create a purchase order" },
    { "name": "list_purchase_orders", "description": "List purchase orders" },
    { "name": "get_bank_accounts", "description": "List registered bank accounts" }
  ]
}
