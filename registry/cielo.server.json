{
  "name": "io.github.codespar/mcp-cielo",
  "description": "Credit/debit card sales, boleto, Pix, recurrence, tokenization — Cielo API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/payments/cielo"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-cielo",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "CIELO_MERCHANT_ID", "description": "MerchantId from Cielo", "required": true },
        { "name": "CIELO_MERCHANT_KEY", "description": "MerchantKey from Cielo", "required": true },
        { "name": "CIELO_SANDBOX", "description": "Set to 'true' for sandbox", "required": false }
      ]
    }
  ],
  "tools": [
    { "name": "create_sale", "description": "Create a credit/debit card sale" },
    { "name": "get_sale", "description": "Get sale details by PaymentId" },
    { "name": "capture_sale", "description": "Capture a pre-authorized sale" },
    { "name": "cancel_sale", "description": "Cancel/void a sale" },
    { "name": "create_recurrent", "description": "Create a recurrent payment" },
    { "name": "get_recurrent", "description": "Get recurrent payment details" },
    { "name": "tokenize_card", "description": "Tokenize a credit card" },
    { "name": "create_boleto", "description": "Create a boleto payment" },
    { "name": "create_pix", "description": "Create a Pix payment" },
    { "name": "get_pix", "description": "Get Pix payment details" },
    { "name": "create_debit", "description": "Create a debit card sale" },
    { "name": "create_ewallet", "description": "Create a digital wallet payment" },
    { "name": "get_antifraud", "description": "Get anti-fraud analysis for a payment" }
  ]
}
