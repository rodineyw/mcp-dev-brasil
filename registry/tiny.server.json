{
  "name": "io.github.codespar/mcp-tiny",
  "description": "Products, orders, contacts, invoices, stock — Tiny ERP API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/erp/tiny"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-tiny",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "TINY_API_TOKEN", "description": "API token from Tiny ERP", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "list_products", "description": "List products" },
    { "name": "get_product", "description": "Get product details" },
    { "name": "list_orders", "description": "List sales orders" },
    { "name": "get_order", "description": "Get order details" },
    { "name": "list_contacts", "description": "List contacts" },
    { "name": "get_contact", "description": "Get contact details" },
    { "name": "create_invoice", "description": "Create a fiscal invoice (NF-e)" },
    { "name": "get_invoice", "description": "Get invoice details" },
    { "name": "get_stock", "description": "Get stock for a product" },
    { "name": "list_accounts_payable", "description": "List accounts payable" }
  ]
}
