{
  "name": "io.github.codespar/mcp-bling",
  "description": "Products, orders, contacts, invoices, stock — Bling ERP API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/erp/bling"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-bling",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "BLING_ACCESS_TOKEN", "description": "OAuth2 access token", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "list_products", "description": "List products" },
    { "name": "create_product", "description": "Create a product" },
    { "name": "list_orders", "description": "List sales orders" },
    { "name": "create_order", "description": "Create a sales order" },
    { "name": "list_contacts", "description": "List contacts (customers/suppliers)" },
    { "name": "create_contact", "description": "Create a contact" },
    { "name": "list_invoices", "description": "List fiscal invoices (NF-e)" },
    { "name": "create_invoice", "description": "Create a fiscal invoice" },
    { "name": "get_stock", "description": "Get stock/inventory for a product" },
    { "name": "update_stock", "description": "Update stock for a product" }
  ]
}
