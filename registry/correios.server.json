{
  "name": "io.github.codespar/mcp-correios",
  "description": "Package tracking, shipping rates, CEP lookup, pre-posting — Correios API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/ecommerce/correios"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-correios",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "CORREIOS_USER", "description": "Correios API username", "required": true },
        { "name": "CORREIOS_TOKEN", "description": "Correios API token", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "track_package", "description": "Track a package by tracking code" },
    { "name": "calculate_shipping", "description": "Calculate shipping rates" },
    { "name": "get_delivery_time", "description": "Get estimated delivery time" },
    { "name": "list_services", "description": "List available shipping services" },
    { "name": "find_cep", "description": "Look up address by CEP" },
    { "name": "create_prepost", "description": "Create a pre-posting order" },
    { "name": "list_postal_codes", "description": "Search addresses by street/location" },
    { "name": "create_collection", "description": "Schedule a package collection (pickup)" },
    { "name": "get_collection", "description": "Get collection request details" },
    { "name": "create_reverse", "description": "Create a reverse logistics (return) order" },
    { "name": "get_reverse", "description": "Get reverse logistics order details" }
  ]
}
