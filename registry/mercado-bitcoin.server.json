{
  "name": "io.github.codespar/mcp-mercado-bitcoin",
  "description": "Ticker, orderbook, orders, trades, balances, candles — Mercado Bitcoin API",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil/tree/main/packages/crypto/mercado-bitcoin"
  },
  "version_detail": {
    "version": "0.1.0",
    "release_date": "2026-03-31",
    "is_latest": true
  },
  "packages": [
    {
      "registry_name": "npm",
      "name": "@codespar/mcp-mercado-bitcoin",
      "version": "0.1.0",
      "runtime": "node",
      "environment_variables": [
        { "name": "MB_API_KEY", "description": "API key from Mercado Bitcoin", "required": true },
        { "name": "MB_API_SECRET", "description": "API secret", "required": true }
      ]
    }
  ],
  "tools": [
    { "name": "get_ticker", "description": "Get ticker data for a trading pair" },
    { "name": "list_orderbook", "description": "Get order book for a trading pair" },
    { "name": "create_order", "description": "Create a buy or sell order" },
    { "name": "get_order", "description": "Get order details by ID" },
    { "name": "cancel_order", "description": "Cancel an open order" },
    { "name": "list_orders", "description": "List orders with filters" },
    { "name": "get_balance", "description": "Get account balances" },
    { "name": "list_trades", "description": "List executed trades" },
    { "name": "get_candles", "description": "Get candlestick/OHLCV data" },
    { "name": "withdraw", "description": "Create a withdrawal request" }
  ]
}
